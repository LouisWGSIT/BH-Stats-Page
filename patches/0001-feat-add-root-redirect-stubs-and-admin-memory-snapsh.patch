+                try:
+                    item = self.queue.get(timeout=1.0)
+                except Exception:
+                    item = None
+                if item is None:
+                    # flush any pending
+                    if batch:
+                        for row in batch:
+                            try:
+                                cur.execute('INSERT INTO activity(ts, request_id, path, method, client_ip, role, note, duration_ms, rss) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)', (
+                                    row.get('ts'), row.get('request_id'), row.get('path'), row.get('method'), row.get('client_ip'), row.get('role'), row.get('note'), row.get('duration_ms'), row.get('rss')
+                                ))
+                            except Exception:
+                                continue
+                        conn.commit()
+                        batch = []
+                    continue
+
+                batch.append(item)
+                # commit in chunks to reduce I/O
+                if len(batch) >= 20:
+                    for row in batch:
+                        try:
+                            cur.execute('INSERT INTO activity(ts, request_id, path, method, client_ip, role, note, duration_ms, rss) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)', (
+                                row.get('ts'), row.get('request_id'), row.get('path'), row.get('method'), row.get('client_ip'), row.get('role'), row.get('note'), row.get('duration_ms'), row.get('rss')
+                            ))
+                        except Exception:
+                            continue
+                    conn.commit()
+                    batch = []
+
+        finally:
+            try:
+                if batch:
+                    for row in batch:
+                        try:
+                            cur.execute('INSERT INTO activity(ts, request_id, path, method, client_ip, role, note, duration_ms, rss) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)', (
+                                row.get('ts'), row.get('request_id'), row.get('path'), row.get('method'), row.get('client_ip'), row.get('role'), row.get('note'), row.get('duration_ms'), row.get('rss')
+                            ))
+                        except Exception:
+                            continue
+                    conn.commit()
+            except Exception:
+                pass
+            try:
+                conn.close()
+            except Exception:
+                pass
+
+    def stop(self):
+        self._stop.set()
+        self._thread.join(timeout=2.0)
+
+    def prune_older_than_days(self, days: int):
+        try:
+            conn = self._get_conn()
+            cur = conn.cursor()
+            cutoff = (datetime.utcnow() - timedelta(days=days)).isoformat()
+            cur.execute('DELETE FROM activity WHERE ts < ?', (cutoff,))
