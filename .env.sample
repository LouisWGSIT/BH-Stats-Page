# Example environment variables for local development
# Copy to .env and fill with real values (DO NOT commit .env)

MARIADB_HOST=your_mariadb_host
MARIADB_USER=your_mariadb_user
MARIADB_PASSWORD=your_db_password_here
MARIADB_DB=your_mariadb_database
MARIADB_PORT=3306

# FastAPI secret (if used)
DASHBOARD_MANAGER_PASSWORD=replace_me
DASHBOARD_ADMIN_PASSWORD=replace_me
 
# Optional alerting webhook for slow DB queries (leave empty to disable)
ALERT_WEBHOOK_URL=
# Threshold in seconds for slow-query alerts (float). Default 2.0
DB_QUERY_ALERT_THRESHOLD=2.0

# Logging level
LOG_LEVEL=INFO
